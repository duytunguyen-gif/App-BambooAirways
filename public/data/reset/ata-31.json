    {
      "id": "display-units-shows-teleloading",
      "aircraftType": "A320 Family",
      "ataChapter": "31",
      "ataTitle": "Indications",
      "faultTitle": "DISPLAY UNITS SHOWS TELELOADING",
      "aircraftConfigurationPriorToReset": [
        "On ground."
      ],
      "circuitBreakersToReset": [],
      "stepsToClearWarning": [
        "First, attempt to switch affected display unit to DMC #3 using switching panel. Next, open associated display unit circuit breaker for 10 seconds, then reset."
      ],
      "results": {
        "pass": "Display unit image is recovered.",
        "fail": "Fault remains."
      },
      "verifiedStatus": "pending",
      "sourceRef": "http://mobile.airlinetechs.com/airbus/31/31teleloading.html",
      "updatedAt": "2026-07-08",
      "cbImage": "data/reset/images/31/teleloading.gif",
      "resetDuration": "5 seconds.",
      "notes": [
        "Also try reset of associated DMC. (DMC #1 = E11) (DMC #2 = Q8) (DMC #3 = Q9). All DMC’s must be the same manufacturer part number."
      ],
      "signOffRefs": [
        "AMM31-60-00-710-001. (EIS start)"
      ],
      "applicableDeferrals": [
        "MEL31-63-01=Display Units."
      ]
    },
    {
      "id": "display-unit-is-blank-or-has-diagonal-line",
      "aircraftType": "A320 Family",
      "ataChapter": "31",
      "ataTitle": "Indications",
      "faultTitle": "DISPLAY UNIT IS BLANK OR HAS DIAGONAL LINE",
      "aircraftConfigurationPriorToReset": [
        "On ground."
      ],
      "circuitBreakersToReset": [],
      "stepsToClearWarning": [
        "First select DMC #3 to isolate fault to DU or DMC. If DMC is at fault reset above associated circuit breaker for 5 seconds. If fault is with DU reset these (CAPT PFD/ND = G3/E1) (FO's PFD/ND = R3/R4) (Upper ECAM = E5) (Lower ECAM = R11)."
      ],
      "results": {
        "pass": "Display operates normally.",
        "fail": "Fault remains."
      },
      "verifiedStatus": "pending",
      "sourceRef": "http://mobile.airlinetechs.com/airbus/31/31blankscreens.html",
      "updatedAt": "2026-07-08",
      "cbImage": "data/reset/images/31/dmc.gif",
      "resetDuration": "5 seconds.",
      "notes": [
        "No notes at this time."
      ],
      "signOffRefs": [
        "AMM31-60-00-710-001. (EIS start)"
      ],
      "applicableDeferrals": [
        "MEL31-63-01=Display Units.",
        "MEL31-63-02=Display Management Computers."
      ]
    },
