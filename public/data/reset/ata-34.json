      "id": "adiru-flashing-align-light-at-alignment",
      "aircraftType": "A320 Family",
      "ataChapter": "34",
      "ataTitle": "Navigation",
      "faultTitle": "ADIRU-FLASHING ALIGN LIGHT AT ALIGNMENT",
      "aircraftConfigurationPriorToReset": [
        "Aircraft on ground, not moving, (PPOS)-present position entered thru MCDU INIT page."
      ],
      "circuitBreakersToReset": [],
      "stepsToClearWarning": [
        "Affected ADIRU, turn the rotary knob on ADIRS control panel to ATT for 5 seconds, then to OFF for 20 seconds, then to NAV. If no help, affected ADIRU needs to cool down. If cool, replace ADIRU."
      ],
      "results": {
        "pass": "Normal alignment.",
        "fail": "Fault remains."
      },
      "verifiedStatus": "pending",
      "sourceRef": "http://mobile.airlinetechs.com/airbus/34/34adiruflashingalignment.html",
      "updatedAt": "2026-07-08",
      "resetDuration": "600 seconds.",
      "signOffRefs": [
        "AMM34-13-00-740-002."
      ],
      "applicableDeferrals": [
        "MEL34-10-01=ADIRS."
      ],
      "cbImages": [
