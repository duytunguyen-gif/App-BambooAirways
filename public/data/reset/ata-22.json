    {
      "id": "auto-flt-a-thr-off-displayed-on-ground",
      "aircraftType": "A320 Family",
      "ataChapter": "22",
      "ataTitle": "Auto Flight",
      "faultTitle": "AUTO FLT-A/THR OFF DISPLAYED ON GROUND",
      "aircraftConfigurationPriorToReset": [
        "ECAM warning displayed and will not clear. Engines shut down."
      ],
      "circuitBreakersToReset": [],
      "stepsToClearWarning": [
        "Select A/THR pushbutton on FCU, the pushbutton will illuminate, then push the red instinctive disconnect button on one of the thrust levers. If message is still displayed, cycle the FADEC switches on the 50VU, if no help reset FCU’s then FMGC’s then try realigning ADIRU’s."
      ],
      "results": {
        "pass": "Message will clear and not recall.",
        "fail": "A/THR OFF message will display."
      },
      "verifiedStatus": "pending",
      "sourceRef": "http://mobile.airlinetechs.com/airbus/22/22autofltathroff.html",
      "updatedAt": "2026-07-08",
      "resetDuration": "10 seconds.",
      "notes": [
        "A/THR pushbutton must not be selected before starting engines. The message is latched and will not clear using the CLR key on the ECAM control panel. If this occurs after engines start,the message will be reset(cleared) upon takeoff power selection. (Thanks Chute for the update)"
      ],
      "signOffRefs": [
        "AMM22-91-00-710-001. (AFS Ground Scan)",
        "AMM22-96-00-710-001-A. (AFS Test)"
      ],
      "applicableDeferrals": [
        "MEL22-30-01=Autothrust Function."
      ]
    },
