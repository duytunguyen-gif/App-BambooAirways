    {
      "id": "f-ctl-altn-law-display-at-engine-start",
      "aircraftType": "A320 Family",
      "ataChapter": "27",
      "ataTitle": "Flight Controls",
      "faultTitle": "F/CTL-ALTN LAW DISPLAY AT ENGINE START",
      "aircraftConfigurationPriorToReset": [
        "On ground, with engines running, wheels chocked."
      ],
      "circuitBreakersToReset": [],
      "stepsToClearWarning": [
        "With engines running, set parking brake, use overhead pushbuttons to switch “OFF” engine hydraulics, when hydraulics are depressurized, select “OFF” ELAC #1 and #2 using overhead swich. After 3 seconds, switch ELAC #1 and ELAC #2 “ON”. After approx 15 seconds, select hydraulics back “ON”."
      ],
      "results": {
        "pass": "Fault clears.",
        "fail": "Fault remains."
      },
      "verifiedStatus": "pending",
      "sourceRef": "http://mobile.airlinetechs.com/airbus/27/27altnlaw.html",
      "updatedAt": "2026-07-08",
      "resetDuration": "30 seconds.",
      "notes": [
        "Follow reset steps closely."
      ],
      "signOffRefs": [
        "AMM27-93-00-710-001."
      ],
      "applicableDeferrals": [
        "No MEL."
      ],
      "cbText": "None"
    },
