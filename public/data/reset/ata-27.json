    {
      "id": "f-ctl-sec-1-2-3-fault-or-splr-fault",
      "aircraftType": "A320 Family",
      "ataChapter": "27",
      "ataTitle": "Flight Controls",
      "faultTitle": "F/CTL-SEC 1(2)(3)FAULT OR SPLR FAULT",
      "aircraftConfigurationPriorToReset": [
        "Aircraft on ground. Hydraulics depressurized."
      ],
      "circuitBreakersToReset": [],
      "stepsToClearWarning": [
        "First, reset applicable SEC pushbutton. If no help, open associated breaker for 5 seconds, then reset. The pushbutton to remain in \"ON\" postion during breaker reset."
      ],
      "results": {
        "pass": "Fault clears.",
        "fail": "Fault remains."
      },
      "verifiedStatus": "pending",
      "sourceRef": "http://mobile.airlinetechs.com/airbus/27/27sec.html",
      "updatedAt": "2026-07-08",
      "cbImage": "data/reset/images/27/sec.gif",
      "resetDuration": "20 seconds.",
      "notes": [
        "If Hydraulics are pressurized, pushbutton reset will not be successful. SEC #1 controls spoilers 3 & 4. SEC #2 controls spoilers 5. SEC #3 controls spoilers 1 & 2."
      ],
      "signOffRefs": [
        "AMM27-94-00-710-001 (SEC #3).",
        "AMM27-94-00-710-002 (SEC #1).",
        "AMM27-94-00-710-003 (SEC #2)."
      ],
      "applicableDeferrals": [
        "MEL27-92-01=SEC’s.",
        "MEL27-92-02=GND Spoilers."
      ]
    },
    {
      "id": "f-ctl-elac-1-2-fault",
      "aircraftType": "A320 Family",
      "ataChapter": "27",
      "ataTitle": "Flight Controls",
      "faultTitle": "F/CTL-ELAC 1(2) FAULT",
      "aircraftConfigurationPriorToReset": [
        "Aircraft on ground."
      ],
      "circuitBreakersToReset": [],
      "stepsToClearWarning": [
        "First, reset applicable ELAC pushbutton. If no help, open associated breaker for 5 seconds. Pushbutton to remain in “ON” position during breaker reset."
      ],
      "results": {
        "pass": "Fault clears.",
        "fail": "Fault remains."
      },
      "verifiedStatus": "pending",
      "sourceRef": "http://mobile.airlinetechs.com/airbus/27/27elac.html",
      "updatedAt": "2026-07-08",
      "cbImage": "data/reset/images/27/elac.gif",
      "resetDuration": "20 seconds.",
      "notes": [
        "ELAC #1 controls left outboard (Blue) and right inboard (Green) aileron servos. ELAC #2 controls Left inboard (Green) and right outboard (Blue) ailerons servos. ELAC #1 is primary in roll, ELAC #2 is primary in pitch. ELAC #1 controls outboard (Blue) elevator servos. ELAC #2 controls inboard left (Green) & inboard right (Yellow) elevator servos."
      ],
      "signOffRefs": [
        "AMM27-93-00-710-001."
      ],
      "applicableDeferrals": [
        "MEL27-93-01=ELEC."
      ]
    },
