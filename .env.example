# ---------------------------------------------------------------------------
# A/C Defects module environment.
# Copy to .env.local for local dev; set the same keys in the Vercel project.
# NEVER commit real secrets. Only the two VITE_* values reach the browser.
# ---------------------------------------------------------------------------

# --- Frontend (safe to expose; embedded in the client bundle) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-only (Vercel functions / scripts; NEVER exposed to the client) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider (pluggable). Use AI_PROVIDER=none to run parser-only. ---
# Approved for Defects cleanup: openai OR gemini, both on PAID no-train accounts.
#   - openai: paid platform account; API data is NOT used for training by default.
#   - gemini: MUST be a PAID project (free AI Studio tier may train on the data).
# All keys are server-only: NEVER add a VITE_ prefix or expose to the client.
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
# Alternative provider (set AI_PROVIDER=gemini + AI_MODEL=gemini-2.5-flash):
GEMINI_API_KEY=

# --- Ops ---
CRON_SECRET=
APP_TIMEZONE=Asia/Ho_Chi_Minh
